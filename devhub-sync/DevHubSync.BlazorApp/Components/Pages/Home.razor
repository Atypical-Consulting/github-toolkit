@page "/"
@rendermode InteractiveServer

<PageTitle>DevHub Sync - Home</PageTitle>

<MudContainer Class="mt-8">
    <MudText Typo="Typo.h2" Align="Align.Center" GutterBottom="true">
        Welcome to DevHub Sync
    </MudText>
    <MudText Typo="Typo.h5" Align="Align.Center" Color="Color.Secondary" GutterBottom="true">
        Seamlessly sync repositories between Azure DevOps and GitHub
    </MudText>
    
    <MudGrid Class="mt-8">
        <MudItem xs="12" md="4">
            <MudCard Elevation="2">
                <MudCardContent>
                    <MudIcon Icon="@Icons.Material.Filled.CloudSync" Size="Size.Large" Color="Color.Primary" />
                    <MudText Typo="Typo.h6" Class="mt-2">Bidirectional Sync</MudText>
                    <MudText Typo="Typo.body2">
                        Copy repositories from DevOps to GitHub, work on GitHub, then sync changes back to DevOps.
                    </MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
        
        <MudItem xs="12" md="4">
            <MudCard Elevation="2">
                <MudCardContent>
                    <MudIcon Icon="@Icons.Material.Filled.Security" Size="Size.Large" Color="Color.Primary" />
                    <MudText Typo="Typo.h6" Class="mt-2">Secure</MudText>
                    <MudText Typo="Typo.body2">
                        Uses Personal Access Tokens for secure authentication with both platforms.
                    </MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
        
        <MudItem xs="12" md="4">
            <MudCard Elevation="2">
                <MudCardContent>
                    <MudIcon Icon="@Icons.Material.Filled.Speed" Size="Size.Large" Color="Color.Primary" />
                    <MudText Typo="Typo.h6" Class="mt-2">Fast & Efficient</MudText>
                    <MudText Typo="Typo.body2">
                        Optimized sync process with real-time progress tracking and detailed logs.
                    </MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
    
    <MudPaper Class="pa-4 mt-8" Elevation="0" Outlined="true">
        <MudText Typo="Typo.h6" GutterBottom="true">Quick Start</MudText>
        <MudList T="string">
            <MudListItem T="string" Icon="@Icons.Material.Filled.Settings">
                Configure your Azure DevOps and GitHub credentials in Settings
            </MudListItem>
            <MudListItem T="string" Icon="@Icons.Material.Filled.Storage">
                Browse and select repositories from either platform
            </MudListItem>
            <MudListItem T="string" Icon="@Icons.Material.Filled.Sync">
                Start a sync operation to copy repositories between platforms
            </MudListItem>
        </MudList>
    </MudPaper>
    
    <MudGrid Class="mt-4">
        <MudItem xs="12" Class="d-flex justify-center gap-4">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Href="/settings">
                Configure Settings
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Large" Href="/repositories">
                Browse Repositories
            </MudButton>
        </MudItem>
    </MudGrid>
</MudContainer>