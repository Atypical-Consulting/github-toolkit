# EditorConfig for Python projects
# https://editorconfig.org

root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
trim_trailing_whitespace = false

[*.{json,yml,yaml,toml}]
indent_size = 2

[*.py]
indent_size = 4
max_line_length = 88

[Makefile]
indent_style = tab
