# EditorConfig for JavaScript/TypeScript projects
# https://editorconfig.org

root = true

[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
trim_trailing_whitespace = false

[*.{json,yml,yaml}]
indent_size = 2

[*.{js,jsx,ts,tsx,mjs,cjs}]
indent_size = 2

[*.{css,scss,less}]
indent_size = 2

[*.{html,vue,svelte}]
indent_size = 2

[Makefile]
indent_style = tab
