@page "/repositories"
@using DevHubSync.BlazorApp.Models
@using DevHubSync.BlazorApp.Services
@using DevHubSync.BlazorApp.Data.Entities
@inject ISyncService SyncService
@inject IDevOpsService DevOpsService
@inject IGitHubService GitHubService
@inject ISnackbar Snackbar
@rendermode InteractiveServer

<PageTitle>Repositories</PageTitle>

<MudText Typo="Typo.h3" GutterBottom="true">Repository Management</MudText>

<MudGrid Class="mb-4">
    <MudItem xs="12" md="4">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="PopulateDevOpsProjects" Disabled="isLoading">
            <MudIcon Icon="@Icons.Custom.Brands.MicrosoftAzure" Class="mr-2" />
            @if (isPopulatingDevOps)
            {
                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                <MudText Class="ms-2">Loading DevOps...</MudText>
            }
            else
            {
                <MudText>Sync DevOps Projects</MudText>
            }
        </MudButton>
    </MudItem>
    <MudItem xs="12" md="4">
        <MudTextField @bind-Value="gitHubOwner" Label="GitHub Owner" Variant="Variant.Outlined" />
    </MudItem>
    <MudItem xs="12" md="4">
        <MudButton Variant="Variant.Filled" Color="Color.Secondary" OnClick="PopulateGitHubRepositories" Disabled="isLoading">
            <MudIcon Icon="@Icons.Custom.Brands.GitHub" Class="mr-2" />
            @if (isPopulatingGitHub)
            {
                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                <MudText Class="ms-2">Loading GitHub...</MudText>
            }
            else
            {
                <MudText>Sync GitHub Repos</MudText>
            }
        </MudButton>
    </MudItem>
</MudGrid>

<MudDataGrid T="RepositoryEntity" @ref="dataGrid" Items="@repositories" Filterable="true" FilterMode="DataGridFilterMode.ColumnFilterRow" 
             SortMode="SortMode.Single" Hideable="true" ShowColumnOptions="true" 
             RowsPerPage="10" Class="mt-4">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Repositories</MudText>
        <MudSpacer />
        <MudTextField @bind-Value="searchString" Placeholder="Search repositories..." Adornment="Adornment.Start"
                      AdornmentIcon="Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" Immediate="true"
                      DebounceInterval="300" OnDebounceIntervalElapsed="OnSearch"></MudTextField>
        <MudButton Variant="Variant.Text" OnClick="RefreshData" StartIcon="@Icons.Material.Filled.Refresh" Class="ml-2">
            Refresh
        </MudButton>
    </ToolBarContent>
    <Columns>
        <PropertyColumn Property="x => x.Name" Title="Name" Sortable="true" Filterable="true">
            <CellTemplate>
                <MudStack Row AlignItems="AlignItems.Center">
                    @if (context.Item.Source == RepositorySource.DevOps)
                    {
                        <MudIcon Icon="@Icons.Custom.Brands.MicrosoftAzure" Color="Color.Primary" Size="Size.Small" />
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Custom.Brands.GitHub" Color="Color.Secondary" Size="Size.Small" />
                    }
                    <MudText>@context.Item.Name</MudText>
                </MudStack>
            </CellTemplate>
        </PropertyColumn>
        
        <PropertyColumn Property="x => x.Description" Title="Description" Sortable="false" Filterable="true">
            <CellTemplate>
                <MudText Style="max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                    @(string.IsNullOrEmpty(context.Item.Description) ? "-" : context.Item.Description)
                </MudText>
            </CellTemplate>
        </PropertyColumn>
        
        <PropertyColumn Property="x => x.Source" Title="Source" Sortable="true" Filterable="true">
            <CellTemplate>
                <MudChip T="string" Size="Size.Small" Color="@(context.Item.Source == RepositorySource.DevOps ? Color.Primary : Color.Secondary)">
                    @context.Item.Source
                </MudChip>
            </CellTemplate>
        </PropertyColumn>
        
        <TemplateColumn Title="Project/Owner" Sortable="false" Filterable="false">
            <CellTemplate>
                @if (context.Item.Source == RepositorySource.DevOps)
                {
                    <MudText>@(context.Item.DevOpsProject?.Name ?? "Unknown")</MudText>
                }
                else
                {
                    <MudText>@(context.Item.GitHubUser?.Username ?? "Unknown")</MudText>
                }
            </CellTemplate>
        </TemplateColumn>
        
        <PropertyColumn Property="x => x.DefaultBranch" Title="Default Branch" Sortable="true" Filterable="true" />
        
        <TemplateColumn Title="Language" Sortable="false" Filterable="false">
            <CellTemplate>
                @if (context.Item.Source == RepositorySource.GitHub && !string.IsNullOrEmpty(context.Item.Language))
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@context.Item.Language</MudChip>
                }
                else
                {
                    <MudText>-</MudText>
                }
            </CellTemplate>
        </TemplateColumn>
        
        <TemplateColumn Title="Stats" Sortable="false" Filterable="false">
            <CellTemplate>
                @if (context.Item.Source == RepositorySource.GitHub)
                {
                    <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Small" Color="Color.Warning" />
                        <MudText Typo="Typo.caption">@context.Item.Stars</MudText>
                        <MudIcon Icon="@Icons.Material.Filled.CallSplit" Size="Size.Small" Color="Color.Info" />
                        <MudText Typo="Typo.caption">@context.Item.Forks</MudText>
                    </MudStack>
                }
                else
                {
                    <MudText>-</MudText>
                }
            </CellTemplate>
        </TemplateColumn>
        
        <TemplateColumn Title="Sync Enabled" Sortable="true" Filterable="false">
            <CellTemplate>
                <MudSwitch T="bool" Value="context.Item.SyncEnabled" 
                          ValueChanged="@(async (value) => await ToggleSyncEnabled(context.Item, value))" 
                          Color="Color.Success" />
            </CellTemplate>
        </TemplateColumn>
        
        <PropertyColumn Property="x => x.SyncStatus" Title="Sync Status" Sortable="true" Filterable="true">
            <CellTemplate>
                <MudChip T="string" Size="Size.Small" Color="@GetSyncStatusColor(context.Item.SyncStatus)">
                    @context.Item.SyncStatus
                </MudChip>
            </CellTemplate>
        </PropertyColumn>
        
        <TemplateColumn Title="Last Updated" Sortable="true" Filterable="false">
            <CellTemplate>
                <MudText Typo="Typo.caption">@context.Item.LastUpdated.ToString("yyyy-MM-dd HH:mm")</MudText>
            </CellTemplate>
        </TemplateColumn>
        
        <TemplateColumn Title="Actions" Sortable="false" Filterable="false">
            <CellTemplate>
                <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small">
                    <MudMenuItem OnClick="@(() => ViewRepository(context.Item))">
                        <MudIcon Icon="@Icons.Material.Filled.Visibility" Class="mr-2" />
                        View Details
                    </MudMenuItem>
                    <MudMenuItem OnClick="@(() => NavigateToSync(context.Item))">
                        <MudIcon Icon="@Icons.Material.Filled.Sync" Class="mr-2" />
                        Start Sync
                    </MudMenuItem>
                    <MudDivider />
                    <MudMenuItem OnClick="@(() => DeleteRepository(context.Item))" 
                                Class="mud-error-text">
                        <MudIcon Icon="@Icons.Material.Filled.Delete" Class="mr-2" />
                        Remove
                    </MudMenuItem>
                </MudMenu>
            </CellTemplate>
        </TemplateColumn>
    </Columns>
    
    <PagerContent>
        <MudDataGridPager T="RepositoryEntity" />
    </PagerContent>
</MudDataGrid>

@code {
    private MudDataGrid<RepositoryEntity> dataGrid = null!;
    private List<RepositoryEntity> repositories = new();
    private List<RepositoryEntity> filteredRepositories = new();
    private string searchString = string.Empty;
    private string gitHubOwner = string.Empty;
    private bool isLoading = false;
    private bool isPopulatingDevOps = false;
    private bool isPopulatingGitHub = false;

    protected override async Task OnInitializedAsync()
    {
        await RefreshData();
    }

    private async Task RefreshData()
    {
        isLoading = true;
        try
        {
            repositories = await SyncService.GetRepositoriesAsync();
            filteredRepositories = repositories;
            if (dataGrid != null)
                await dataGrid.ReloadServerData();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load repositories: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task PopulateDevOpsProjects()
    {
        isPopulatingDevOps = true;
        try
        {
            var projectCount = await SyncService.PopulateDevOpsProjectsAsync();
            Snackbar.Add($"Synchronized {projectCount} DevOps projects", Severity.Success);
            
            // Now populate repositories for each project
            var projects = await SyncService.GetDevOpsProjectsAsync();
            int totalRepos = 0;
            
            foreach (var project in projects)
            {
                try
                {
                    var repoCount = await SyncService.PopulateDevOpsRepositoriesAsync(project.ProjectId);
                    totalRepos += repoCount;
                }
                catch (Exception ex)
                {
                    Snackbar.Add($"Failed to sync repositories for project {project.Name}: {ex.Message}", Severity.Warning);
                }
            }
            
            Snackbar.Add($"Synchronized {totalRepos} DevOps repositories", Severity.Success);
            await RefreshData();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to populate DevOps data: {ex.Message}", Severity.Error);
        }
        finally
        {
            isPopulatingDevOps = false;
        }
    }

    private async Task PopulateGitHubRepositories()
    {
        isPopulatingGitHub = true;
        try
        {
            var repoCount = await SyncService.PopulateGitHubRepositoriesAsync(string.IsNullOrEmpty(gitHubOwner) ? null : gitHubOwner);
            Snackbar.Add($"Synchronized {repoCount} GitHub repositories", Severity.Success);
            await RefreshData();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to populate GitHub repositories: {ex.Message}", Severity.Error);
        }
        finally
        {
            isPopulatingGitHub = false;
        }
    }

    private async Task ToggleSyncEnabled(RepositoryEntity repository, bool enabled)
    {
        try
        {
            repository.SyncEnabled = enabled;
            await SyncService.CreateOrUpdateRepositoryAsync(repository);
            Snackbar.Add($"Sync {(enabled ? "enabled" : "disabled")} for {repository.Name}", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to update sync status: {ex.Message}", Severity.Error);
            repository.SyncEnabled = !enabled; // Revert on error
        }
    }

    private void OnSearch()
    {
        if (string.IsNullOrWhiteSpace(searchString))
        {
            filteredRepositories = repositories;
        }
        else
        {
            filteredRepositories = repositories.Where(r => 
                r.Name.Contains(searchString, StringComparison.OrdinalIgnoreCase) ||
                r.Description.Contains(searchString, StringComparison.OrdinalIgnoreCase) ||
                (r.DevOpsProject?.Name.Contains(searchString, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (r.GitHubUser?.Username.Contains(searchString, StringComparison.OrdinalIgnoreCase) ?? false)
            ).ToList();
        }
        
        StateHasChanged();
    }

    private void ViewRepository(RepositoryEntity repository)
    {
        Snackbar.Add($"Repository details for {repository.Name} coming soon!", Severity.Info);
    }

    private void NavigateToSync(RepositoryEntity repository)
    {
        Snackbar.Add($"Navigate to sync page for {repository.Name} coming soon!", Severity.Info);
    }

    private async Task DeleteRepository(RepositoryEntity repository)
    {
        try
        {
            var success = await SyncService.DeleteRepositoryAsync(repository.Id);
            if (success)
            {
                Snackbar.Add($"Repository {repository.Name} removed from database", Severity.Success);
                await RefreshData();
            }
            else
            {
                Snackbar.Add("Failed to remove repository", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to delete repository: {ex.Message}", Severity.Error);
        }
    }

    private Color GetSyncStatusColor(SyncStatus status) => status switch
    {
        SyncStatus.Synced => Color.Success,
        SyncStatus.Failed => Color.Error,
        SyncStatus.Syncing => Color.Info,
        SyncStatus.NotSynced => Color.Default,
        _ => Color.Default
    };
}