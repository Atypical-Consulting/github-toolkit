@page "/sync"
@using DevHubSync.BlazorApp.Models
@using DevHubSync.BlazorApp.Services
@using DevHubSync.BlazorApp.Data.Entities
@inject ISyncService SyncService
@inject IDevOpsService DevOpsService
@inject IGitHubService GitHubService
@inject ISnackbar Snackbar
@rendermode InteractiveServer
@implements IDisposable

<PageTitle>Sync Operations</PageTitle>

<MudText Typo="Typo.h3" GutterBottom="true">Sync Operations</MudText>

<MudGrid>
    <MudItem xs="12" md="6">
        <MudCard>
            <MudCardContent>
                <MudText Typo="Typo.h6">New Sync Operation</MudText>
                <MudSelect T="SyncDirection" Label="Sync Direction" @bind-Value="syncDirection" Variant="Variant.Outlined" Class="mt-4">
                    <MudSelectItem Value="SyncDirection.DevOpsToGitHub">DevOps → GitHub</MudSelectItem>
                    <MudSelectItem Value="SyncDirection.GitHubToDevOps">GitHub → DevOps</MudSelectItem>
                </MudSelect>
                
                @if (syncDirection == SyncDirection.DevOpsToGitHub)
                {
                    <MudAutocomplete T="DevOpsProject" 
                                   Label="DevOps Project" 
                                   @bind-Value="selectedDevOpsProject"
                                   SearchFunc="SearchDevOpsProjects"
                                   ToStringFunc="@(p => p?.Name ?? string.Empty)"
                                   Variant="Variant.Outlined" 
                                   Class="mt-2"
                                   ResetValueOnEmptyText="true"
                                   CoerceText="false" />
                    
                    <MudAutocomplete T="RepositoryEntity" 
                                   Label="DevOps Repository" 
                                   @bind-Value="selectedDevOpsRepository"
                                   SearchFunc="SearchDevOpsRepositories"
                                   ToStringFunc="@(r => r?.Name ?? string.Empty)"
                                   Variant="Variant.Outlined" 
                                   Class="mt-2"
                                   ResetValueOnEmptyText="true"
                                   CoerceText="false"
                                   Disabled="selectedDevOpsProject == null" />
                    
                    <MudAutocomplete T="GitHubUser" 
                                   Label="GitHub Owner" 
                                   @bind-Value="selectedGitHubUser"
                                   SearchFunc="SearchGitHubUsers"
                                   ToStringFunc="@(u => u?.Username ?? string.Empty)"
                                   Variant="Variant.Outlined" 
                                   Class="mt-2"
                                   ResetValueOnEmptyText="true"
                                   CoerceText="false" />
                    
                    <MudTextField @bind-Value="gitHubRepoName" Label="GitHub Repository Name (optional)" Variant="Variant.Outlined" Class="mt-2" />
                }
                else
                {
                    <MudAutocomplete T="GitHubUser" 
                                   Label="GitHub Owner" 
                                   @bind-Value="selectedGitHubUser"
                                   SearchFunc="SearchGitHubUsers"
                                   ToStringFunc="@(u => u?.Username ?? string.Empty)"
                                   Variant="Variant.Outlined" 
                                   Class="mt-2"
                                   ResetValueOnEmptyText="true"
                                   CoerceText="false" />
                    
                    <MudAutocomplete T="RepositoryEntity" 
                                   Label="GitHub Repository" 
                                   @bind-Value="selectedGitHubRepository"
                                   SearchFunc="SearchGitHubRepositories"
                                   ToStringFunc="@(r => r?.Name ?? string.Empty)"
                                   Variant="Variant.Outlined" 
                                   Class="mt-2"
                                   ResetValueOnEmptyText="true"
                                   CoerceText="false"
                                   Disabled="selectedGitHubUser == null" />
                    
                    <MudAutocomplete T="DevOpsProject" 
                                   Label="DevOps Project" 
                                   @bind-Value="selectedDevOpsProject"
                                   SearchFunc="SearchDevOpsProjects"
                                   ToStringFunc="@(p => p?.Name ?? string.Empty)"
                                   Variant="Variant.Outlined" 
                                   Class="mt-2"
                                   ResetValueOnEmptyText="true"
                                   CoerceText="false" />
                    
                    <MudAutocomplete T="RepositoryEntity" 
                                   Label="DevOps Repository" 
                                   @bind-Value="selectedDevOpsRepository"
                                   SearchFunc="SearchDevOpsRepositories"
                                   ToStringFunc="@(r => r?.Name ?? string.Empty)"
                                   Variant="Variant.Outlined" 
                                   Class="mt-2"
                                   ResetValueOnEmptyText="true"
                                   CoerceText="false"
                                   Disabled="selectedDevOpsProject == null" />
                }
            </MudCardContent>
            <MudCardActions>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="StartSync" Disabled="@(!CanStartSync() || isSyncing)">
                    @if (isSyncing)
                    {
                        <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                        <MudText Class="ms-2">Syncing...</MudText>
                    }
                    else
                    {
                        <MudText>Start Sync</MudText>
                    }
                </MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>
    
    <MudItem xs="12" md="6">
        @if (currentOperation != null)
        {
            <MudCard>
                <MudCardContent>
                    <MudText Typo="Typo.h6">Current Operation</MudText>
                    <MudText Typo="Typo.body2" Class="mt-2">ID: @currentOperation.Id</MudText>
                    <MudText Typo="Typo.body2">Direction: @currentOperation.Direction</MudText>
                    <MudText Typo="Typo.body2">Status: 
                        <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(currentOperation.Status)">
                            @currentOperation.Status
                        </MudChip>
                    </MudText>
                    @if (!string.IsNullOrEmpty(currentOperation.ErrorMessage))
                    {
                        <MudAlert Severity="Severity.Error" Class="mt-2">@currentOperation.ErrorMessage</MudAlert>
                    }
                    
                    <MudText Typo="Typo.h6" Class="mt-4">Logs</MudText>
                    <MudPaper Class="pa-2 mt-2" Style="max-height: 200px; overflow-y: auto;">
                        @foreach (var log in currentOperation.Logs)
                        {
                            <MudText Typo="Typo.body2" Color="@GetLogColor(log.Level)">
                                [@log.Timestamp.ToString("HH:mm:ss")] @log.Message
                            </MudText>
                        }
                    </MudPaper>
                </MudCardContent>
            </MudCard>
        }
    </MudItem>
</MudGrid>

<MudText Typo="Typo.h5" Class="mt-6 mb-4">Sync History</MudText>

@if (syncHistory.Any())
{
    <MudTable Items="@syncHistory" Hover="true" Breakpoint="Breakpoint.Sm">
        <HeaderContent>
            <MudTh>Start Time</MudTh>
            <MudTh>Direction</MudTh>
            <MudTh>Source</MudTh>
            <MudTh>Target</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Duration</MudTh>
            <MudTh>Error</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Start Time">@context.StartTime.ToString("yyyy-MM-dd HH:mm:ss")</MudTd>
            <MudTd DataLabel="Direction">@context.Direction</MudTd>
            <MudTd DataLabel="Source">@context.SourceRepositoryId</MudTd>
            <MudTd DataLabel="Target">@(context.TargetRepositoryId ?? "N/A")</MudTd>
            <MudTd DataLabel="Status">
                <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status)">
                    @context.Status
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Duration">
                @if (context.EndTime.HasValue)
                {
                    @((context.EndTime.Value - context.StartTime).ToString(@"mm\:ss"))
                }
                else
                {
                    <text>-</text>
                }
            </MudTd>
            <MudTd DataLabel="Error">
                @if (!string.IsNullOrEmpty(context.ErrorMessage))
                {
                    <MudTooltip Text="@context.ErrorMessage">
                        <MudIcon Icon="@Icons.Material.Filled.Error" Color="Color.Error" />
                    </MudTooltip>
                }
            </MudTd>
        </RowTemplate>
    </MudTable>
}
else
{
    <MudAlert Severity="Severity.Info">No sync operations yet.</MudAlert>
}

@code {
    private SyncDirection syncDirection = SyncDirection.DevOpsToGitHub;
    private string gitHubRepoName = string.Empty;
    private bool isSyncing = false;
    private SyncOperation? currentOperation;
    private List<SyncOperation> syncHistory = new();
    
    // Autocomplete selected values
    private DevOpsProject? selectedDevOpsProject;
    private GitHubUser? selectedGitHubUser;
    private RepositoryEntity? selectedDevOpsRepository;
    private RepositoryEntity? selectedGitHubRepository;
    
    // Data lists for autocomplete
    private List<DevOpsProject> devOpsProjects = new();
    private List<GitHubUser> gitHubUsers = new();
    private List<RepositoryEntity> devOpsRepositories = new();
    private List<RepositoryEntity> gitHubRepositories = new();

    protected override async Task OnInitializedAsync()
    {
        SyncService.SyncProgressChanged += OnSyncProgressChanged;
        await LoadData();
    }

    private async Task LoadData()
    {
        await LoadSyncHistory();
        devOpsProjects = await SyncService.GetDevOpsProjectsAsync();
        gitHubUsers = await SyncService.GetGitHubUsersAsync();
        devOpsRepositories = await SyncService.GetDevOpsRepositoriesAsync();
        gitHubRepositories = await SyncService.GetGitHubRepositoriesAsync();
    }

    private async Task LoadSyncHistory()
    {
        syncHistory = await SyncService.GetSyncHistoryAsync();
    }

    private Task<IEnumerable<DevOpsProject>> SearchDevOpsProjects(string value, CancellationToken token)
    {
        if (string.IsNullOrEmpty(value))
            return Task.FromResult(devOpsProjects.AsEnumerable());
        
        return Task.FromResult(devOpsProjects.Where(p => p.Name.Contains(value, StringComparison.InvariantCultureIgnoreCase)));
    }

    private Task<IEnumerable<GitHubUser>> SearchGitHubUsers(string value, CancellationToken token)
    {
        if (string.IsNullOrEmpty(value))
            return Task.FromResult(gitHubUsers.AsEnumerable());
        
        return Task.FromResult(gitHubUsers.Where(u => u.Username.Contains(value, StringComparison.InvariantCultureIgnoreCase) ||
                                     u.DisplayName.Contains(value, StringComparison.InvariantCultureIgnoreCase)));
    }

    private Task<IEnumerable<RepositoryEntity>> SearchDevOpsRepositories(string value, CancellationToken token)
    {
        var repos = selectedDevOpsProject != null 
            ? devOpsRepositories.Where(r => r.DevOpsProjectId == selectedDevOpsProject.Id)
            : devOpsRepositories;
        
        if (string.IsNullOrEmpty(value))
            return Task.FromResult(repos.AsEnumerable());
        
        return Task.FromResult(repos.Where(r => r.Name.Contains(value, StringComparison.InvariantCultureIgnoreCase)));
    }

    private Task<IEnumerable<RepositoryEntity>> SearchGitHubRepositories(string value, CancellationToken token)
    {
        var repos = selectedGitHubUser != null 
            ? gitHubRepositories.Where(r => r.GitHubUserId == selectedGitHubUser.Id)
            : gitHubRepositories;
        
        if (string.IsNullOrEmpty(value))
            return Task.FromResult(repos.AsEnumerable());
        
        return Task.FromResult(repos.Where(r => r.Name.Contains(value, StringComparison.InvariantCultureIgnoreCase)));
    }

    private bool CanStartSync()
    {
        if (syncDirection == SyncDirection.DevOpsToGitHub)
        {
            return selectedDevOpsProject != null && selectedDevOpsRepository != null && selectedGitHubUser != null;
        }
        else
        {
            return selectedGitHubUser != null && selectedGitHubRepository != null && 
                   selectedDevOpsProject != null && selectedDevOpsRepository != null;
        }
    }

    private async Task StartSync()
    {
        if (!CanStartSync()) return;
        
        isSyncing = true;
        
        try
        {
            if (syncDirection == SyncDirection.DevOpsToGitHub)
            {
                currentOperation = await SyncService.SyncDevOpsToGitHubAsync(
                    selectedDevOpsProject!.ProjectId,
                    selectedDevOpsRepository!.ExternalId,
                    selectedGitHubUser!.Username,
                    string.IsNullOrEmpty(gitHubRepoName) ? null : gitHubRepoName
                );
            }
            else
            {
                currentOperation = await SyncService.SyncGitHubToDevOpsAsync(
                    selectedGitHubUser!.Username,
                    selectedGitHubRepository!.Name,
                    selectedDevOpsProject!.ProjectId,
                    selectedDevOpsRepository!.ExternalId
                );
            }
            
            await LoadSyncHistory();
            
            if (currentOperation.Status == SyncOperationStatus.Completed)
            {
                Snackbar.Add("Sync completed successfully!", Severity.Success);
            }
            else if (currentOperation.Status == SyncOperationStatus.Failed)
            {
                Snackbar.Add($"Sync failed: {currentOperation.ErrorMessage}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to start sync: {ex.Message}", Severity.Error);
        }
        finally
        {
            isSyncing = false;
        }
    }

    private async void OnSyncProgressChanged(object? sender, SyncOperation operation)
    {
        if (currentOperation?.Id == operation.Id)
        {
            // Reload the current operation from the database to get latest logs
            var updatedOperation = await SyncService.GetSyncOperationAsync(operation.Id);
            if (updatedOperation != null)
            {
                currentOperation = updatedOperation;
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private Color GetStatusColor(SyncOperationStatus status) => status switch
    {
        SyncOperationStatus.Completed => Color.Success,
        SyncOperationStatus.Failed => Color.Error,
        SyncOperationStatus.InProgress => Color.Info,
        SyncOperationStatus.Cancelled => Color.Warning,
        _ => Color.Default
    };

    private Color GetLogColor(LogLevel level) => level switch
    {
        LogLevel.Error => Color.Error,
        LogLevel.Warning => Color.Warning,
        _ => Color.Default
    };

    public void Dispose()
    {
        SyncService.SyncProgressChanged -= OnSyncProgressChanged;
    }
}